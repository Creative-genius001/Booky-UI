# Base URL of the Bookly Go backend (barber-booking-backend).
# In the browser this is used directly, so it must be reachable from the client.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional: when set, Next.js proxies /api/backend/* -> $API_PROXY_TARGET/* (dev only, avoids CORS).
# Leave NEXT_PUBLIC_API_BASE_URL=/api/backend to route through the proxy.
# API_PROXY_TARGET=http://localhost:8080

# Public base URL of this frontend (used to build Paystack callback URLs).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mapbox public token for the /discover map + address geocoding (optional;
# the app degrades to a list-only experience without it).
NEXT_PUBLIC_MAPBOX_TOKEN=
